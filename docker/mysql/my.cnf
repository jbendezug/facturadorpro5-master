[mysqld]
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci
default-storage-engine = InnoDB
# Requerido por hyn/multi-tenant para crear bases de datos dinámicas
innodb_file_per_table = 1
# Performance básica
innodb_buffer_pool_size = 256M
# MySQL 8.0: max_allowed_packet va en la sección mysqld
max_allowed_packet = 64M
# Modo SQL compatible con Laravel 5.7
# NOTA: NO_AUTO_CREATE_USER fue eliminado en MySQL 8.0
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION
# MySQL 8.0: usar autenticación legacy para compatibilidad con PHP 7.4 PDO
default_authentication_plugin = mysql_native_password

[client]
default-character-set = utf8mb4
