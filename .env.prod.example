APP_NAME="FacturadorPro5"
APP_ENV=production
APP_KEY=                            # genera con: php artisan key:generate --show
APP_DEBUG=false
APP_URL_BASE=tudominio.com
APP_URL=https://tudominio.com

LOG_CHANNEL=daily

# Base de datos (el host "mysql" es el contenedor interno)
DB_CONNECTION=system
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tenancy
DB_USERNAME=root
DB_PASSWORD=CAMBIA_ESTA_CONTRASENA_SEGURA

# Redis
BROADCAST_DRIVER=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Correo SMTP
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=tucorreo@gmail.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=tucorreo@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

# Pusher (dejar en blanco si no se usa)
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Multi-Tenant (hyn)
LIMIT_UUID_LENGTH_32=true
TENANCY_DATABASE_AUTO_DELETE=true
TENANCY_DATABASE_AUTO_DELETE_USER=true
PREFIX_DATABASE=tenancy

# Aplicación
ITEMS_PER_PAGE=20
ITEMS_PER_PAGE_SIMPLE_D_TABLE=5
PASSWORD_CHANGE=true

# OSE / CPE
SIGNATURE_NOTE_OSE=FACTURALO
SIGNATURE_URI_OSE=signatureFACTURALOPERU
IS_CLIENT=false
TOKEN_SERVER=
URL_SERVER=

# Documentos
RECREATE_DOCUMENT=false
IMPORT_DOCUMENTS=false
IMPORT_DOCUMENTS_SECOND_FORMAT=false

# PDF
PDF_TEMPLATE=default
PDF_TEMPLATE_FOOTER=true
PDF_NAME_REGULAR=false
PDF_NAME_BOLD=false
ENABLED_TEMPLATE_TICKET_80=false

# Descuentos y estados
ENABLED_DISCOUNT_GLOBAL=false
CHANGE_TO_REGISTERED_STATUS=false
DOCUMENT_TYPE_03_FILTER=false

# API de consulta RUC/DNI/Tipo de cambio (migo.pe)
API_SERVICE_URL=https://api.migo.pe
API_SERVICE_TOKEN=                      # ingresa tu token de api.migo.pe

# HTTPS (pon true si el Nginx externo ya termina SSL)
FORCE_HTTPS=true
